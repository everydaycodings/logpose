// LogPose — personal music library schema
// Run migrations with: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TrackSource {
  UPLOAD
  YOUTUBE
}

enum ImportType {
  UPLOAD
  YOUTUBE
  YOUTUBE_PLAYLIST
  REENRICH
  RESTORE
}

enum ImportStatus {
  QUEUED
  DOWNLOADING
  TRANSCODING
  FETCHING_META
  DONE
  FAILED
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  // Normalized (lowercased, trimmed) name for dedup/upsert.
  slug      String   @unique
  coverKey  String?
  mbid      String?
  createdAt DateTime @default(now())

  albums Album[]
  tracks Track[]
}

model Album {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique // normalized "artist::title"
  year      Int?
  coverKey  String?
  mbid      String?
  createdAt DateTime @default(now())

  artistId String
  artist   Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks   Track[]

  @@index([artistId])
}

model Track {
  id          String      @id @default(cuid())
  title       String
  trackNumber Int?
  durationMs  Int?
  year        Int?
  genre       String?
  lyrics       String? @db.Text
  syncedLyrics String? @db.Text // LRC format from lrclib.net
  source       TrackSource
  sourceUrl   String?
  mbid        String?

  // Object storage keys (MinIO / S3).
  originalKey String? // original uploaded/downloaded file
  mp3Key      String? // browser-friendly transcode used for playback
  coverKey    String?

  liked        Boolean   @default(false)
  playCount    Int       @default(0)
  lastPlayedAt DateTime?
  createdAt    DateTime  @default(now())

  artistId String?
  artist   Artist? @relation(fields: [artistId], references: [id], onDelete: SetNull)
  albumId  String?
  album    Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)

  playlistEntries PlaylistTrack[]
  playEvents      PlayEvent[]

  @@index([artistId])
  @@index([albumId])
  @@index([liked])
  @@index([createdAt])
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverKey    String?
  createdAt   DateTime @default(now())

  tracks PlaylistTrack[]
}

model PlaylistTrack {
  id         String @id @default(cuid())
  playlistId String
  trackId    String
  position   Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, position])
}

// One row per play (recorded when a track starts). Powers listening history,
// "on this day", total listening time, and the stats dashboard.
model PlayEvent {
  id       String   @id @default(cuid())
  trackId  String
  playedAt DateTime @default(now())
  // Snapshot of duration so stats survive track deletion.
  durationMs Int?

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([playedAt])
  @@index([trackId])
}

// Generic key/value store for app settings (e.g. Last.fm session key).
model Setting {
  key   String @id
  value String
}

model ImportJob {
  id        String       @id @default(cuid())
  type      ImportType
  status    ImportStatus @default(QUEUED)
  progress  Int          @default(0)
  // Source: YouTube URL or original upload filename.
  sourceUrl String?
  filename  String?
  // Temp object key for an upload awaiting processing.
  uploadKey String?
  error     String?
  trackId   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}
